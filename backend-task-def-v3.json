{
  "family": "codewarts-backend",
  "taskRoleArn": "arn:aws:iam::148221445428:role/codewarts-ecs-task-execution-role",
  "executionRoleArn": "arn:aws:iam::148221445428:role/codewarts-ecs-task-execution-role",
  "networkMode": "awsvpc",
  "containerDefinitions": [
    {
      "name": "backend",
      "image": "148221445428.dkr.ecr.us-east-1.amazonaws.com/codewarts-backend:latest",
      "cpu": 0,
      "memoryReservation": 384,
      "essential": true,
      "portMappings": [
        {
          "containerPort": 8080,
          "hostPort": 8080,
          "protocol": "tcp"
        }
      ],
      "environment": [
        {
          "name": "PORT",
          "value": "8080"
        },
        {
          "name": "DB_PORT",
          "value": "5432"
        },
        {
          "name": "DB_SSLMODE",
          "value": "require"
        },
        {
          "name": "DEV_MODE",
          "value": "true"
        },
        {
          "name": "JWT_SECRET",
          "value": "cybersecret_99_key"
        }
      ],
      "secrets": [
        {
          "name": "SMTP_HOST",
          "valueFrom": "arn:aws:secretsmanager:us-east-1:148221445428:secret:codewarts/smtp-GTkgD7:SMTP_HOST::"
        },
        {
          "name": "SMTP_PORT",
          "valueFrom": "arn:aws:secretsmanager:us-east-1:148221445428:secret:codewarts/smtp-GTkgD7:SMTP_PORT::"
        },
        {
          "name": "SMTP_USER",
          "valueFrom": "arn:aws:secretsmanager:us-east-1:148221445428:secret:codewarts/smtp-GTkgD7:SMTP_USER::"
        },
        {
          "name": "SMTP_PASS",
          "valueFrom": "arn:aws:secretsmanager:us-east-1:148221445428:secret:codewarts/smtp-GTkgD7:SMTP_PASS::"
        },
        {
          "name": "SMTP_SENDER",
          "valueFrom": "arn:aws:secretsmanager:us-east-1:148221445428:secret:codewarts/smtp-GTkgD7:SMTP_SENDER::"
        },
        {
          "name": "BREVO_API_KEY",
          "valueFrom": "arn:aws:secretsmanager:us-east-1:148221445428:secret:codewarts/smtp-GTkgD7:BREVO_API_KEY::"
        },
        {
          "name": "DB_HOST",
          "valueFrom": "arn:aws:secretsmanager:us-east-1:148221445428:secret:codewarts/smtp-GTkgD7:DB_HOST::"
        },
        {
          "name": "DB_USER",
          "valueFrom": "arn:aws:secretsmanager:us-east-1:148221445428:secret:codewarts/smtp-GTkgD7:DB_USER::"
        },
        {
          "name": "DB_PASSWORD",
          "valueFrom": "arn:aws:secretsmanager:us-east-1:148221445428:secret:codewarts/smtp-GTkgD7:DB_PASSWORD::"
        },
        {
          "name": "DB_NAME",
          "valueFrom": "arn:aws:secretsmanager:us-east-1:148221445428:secret:codewarts/smtp-GTkgD7:DB_NAME::"
        }
      ],
      "mountPoints": [
        {
          "sourceVolume": "docker-socket",
          "containerPath": "/var/run/docker.sock"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/codewarts-backend",
          "awslogs-region": "us-east-1",
          "awslogs-stream-prefix": "ecs"
        }
      }
    }
  ],
  "requiresCompatibilities": [
    "EC2"
  ],
  "cpu": "512",
  "memory": "512",
  "volumes": [
    {
      "name": "docker-socket",
      "host": {
        "sourcePath": "/var/run/docker.sock"
      }
    }
  ]
}
